# Repository policy: build/ is the only supported location for generated files.
# Do not ignore build-*, out/, object/module files, coverage data, or in-source
# CMake output: those violate the project layout and must remain visible.
/build/

# User-local CMake configuration must not change the repository build contract.
/CMakeUserPresets.json

# Operating-system metadata.
.DS_Store
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Repository-local editor and language-server state.
/.cache/clangd/
/.clangd/
/.idea/
/.vs/
/.vscode/

# Editor and IDE files that may appear beside source files.
*.code-workspace
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb
*.swp
*.swo
*.swn
*.un~
*.xcuserstate
*~
.\#*
\#*\#
xcuserdata/

# Python tooling used by numerical-report scripts.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
/.venv/
/venv/

# Local environment files may contain credentials.  A documented example may
# still be committed.
/.env
/.env.*
!/.env.example

# Crash dumps and editor/patch leftovers.
/core
/core.*
/vgcore.*
/*.dmp
/*.stackdump
*.bak
*.orig
*.rej
*.tmp
*.temp
